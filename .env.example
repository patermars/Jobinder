# Adzuna — free tier, 250 req/month
# Sign up: https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=in   # in=India, us=USA, gb=UK, ca=Canada, au=Australia

# JSearch via RapidAPI — aggregates Indeed, LinkedIn, Glassdoor, Naukri, Wellfound, Handshake
# Sign up: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch (free: 200 req/month)
JSEARCH_API_KEY=your_rapidapi_key
JSEARCH_COUNTRY=IN  # IN=India, US=USA, GB=UK, CA=Canada, AU=Australia

# Comma-separated search queries for the 12-hour sync
SYNC_QUERIES=software engineer,data scientist,machine learning engineer,devops engineer,product manager
